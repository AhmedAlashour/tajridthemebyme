{# ── TESTIMONIALS ── #}
<section class="cof-sec">
  <div class="cof-sec__head">
    <div><span class="cof-sec__tag">Testimonials</span><h2 class="cof-sec__title">{{ trans('common.titles.what_say', 'What') }} <strong>{{ trans('common.titles.customers_say', 'Customers Say') }}</strong></h2></div>
  </div>
  <div class="cof-tests">
    {% for testimonial in store.testimonials | default([]) | slice(0, 3) %}
      <div class="cof-test">
        <div class="cof-test__stars">{% for i in 1..testimonial.rating %}<svg width="11" height="11" viewBox="0 0 12 12" fill="currentColor"><path d="M6 0l1.76 3.57 3.94.58-2.85 2.78.67 3.93L6 8.9l-3.52 1.96.67-3.93L.3 4.15l3.94-.58z"/></svg>{% endfor %}</div>
        <p class="cof-test__txt">"{{ testimonial.text }}"</p>
        <div class="cof-test__author">{{ testimonial.author }}</div>
      </div>
    {% else %}
      {% set reviews = [
        {r:5, t:trans('common.titles.rev1','Best specialty coffee. Fresh roast, exceptional flavor.'), a:trans('common.titles.rev1a','Ahmed')},
        {r:5, t:trans('common.titles.rev2','Fast delivery, elegant packaging. My daily coffee now.'), a:trans('common.titles.rev2a','Noura')},
        {r:5, t:trans('common.titles.rev3','The subscription changed my coffee experience completely.'), a:trans('common.titles.rev3a','Khaled')}
      ] %}
      {% for rv in reviews %}
        <div class="cof-test">
          <div class="cof-test__stars">{% for i in 1..rv.r %}<svg width="11" height="11" viewBox="0 0 12 12" fill="currentColor"><path d="M6 0l1.76 3.57 3.94.58-2.85 2.78.67 3.93L6 8.9l-3.52 1.96.67-3.93L.3 4.15l3.94-.58z"/></svg>{% endfor %}</div>
          <p class="cof-test__txt">"{{ rv.t }}"</p>
          <div class="cof-test__author">{{ rv.a }}</div>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</section>
