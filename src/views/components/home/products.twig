{# ── PRODUCTS GRID with Salla Cart SDK ── #}
<section class="cof-sec" id="products">
  <div class="cof-sec__head">
    <div><span class="cof-sec__tag">Specialty Coffee</span><h2 class="cof-sec__title">{{ trans('common.titles.coffee', 'Specialty') }} <strong>{{ trans('common.titles.specialty', 'Coffee') }}</strong></h2></div>
    <a href="{{ link('products') }}" class="cof-sec__link">{{ trans('common.titles.view_all', 'View All') }}
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><line x1="0" y1="8" x2="14" y2="8"/><polyline points="8,2 14,8 8,14"/></svg>
    </a>
  </div>
  <div class="cof-prods">
    {% for product in products %}
      <article class="cof-prod">
        <a href="{{ product.url }}" class="cof-prod__img">
          {% if product.promotion.title %}<div class="cof-prod__badge">{{ product.promotion.title }}</div>{% endif %}
          {% if product.image.url %}
            <img src="{{ product.image.url }}" alt="{{ product.name }}" loading="lazy" width="400" height="533">
          {% else %}
            <div class="cof-prod__placeholder"><span class="cof-prod__vis-name">{{ product.name }}</span></div>
          {% endif %}
          {% if product.is_available %}
            <button class="cof-prod__add" onclick="event.preventDefault();salla.cart.addItem({id:{{ product.id }},quantity:1}).then(()=>salla.event.emit('cart::open'))">{{ trans('common.titles.add_cart', 'Add to Cart') }}</button>
          {% else %}
            <div class="cof-prod__add" style="background:var(--cof-g5);cursor:default">{{ trans('common.titles.sold_out', 'Sold Out') }}</div>
          {% endif %}
        </a>
        <div class="cof-prod__info">
          <a href="{{ product.url }}"><h3 class="cof-prod__name">{{ product.name }}</h3></a>
          <div class="cof-prod__meta">
            <div class="cof-prod__prices">
              <span class="cof-prod__price">{{ product.price }} <span class="cof-prod__cur">{{ product.currency }}</span></span>
              {% if product.sale_price %}<span class="cof-prod__old">{{ product.regular_price }}</span>{% endif %}
            </div>
            {% if product.rating and product.rating.count > 0 %}
              <div class="cof-prod__rate"><svg width="11" height="11" viewBox="0 0 12 12" fill="currentColor"><path d="M6 0l1.76 3.57 3.94.58-2.85 2.78.67 3.93L6 8.9l-3.52 1.96.67-3.93L.3 4.15l3.94-.58z"/></svg>{{ product.rating.stars }}</div>
            {% endif %}
          </div>
        </div>
      </article>
    {% else %}
      <p style="grid-column:1/-1;text-align:center;color:var(--cof-g4);padding:3rem">{{ trans('common.titles.no_products', 'No products yet.') }}</p>
    {% endfor %}
  </div>
</section>
