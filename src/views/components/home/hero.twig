{# ── HERO: Full-screen video background ── #}
<section class="cof-hero" id="hero">
  <div class="cof-hero__video-wrap">
    <video class="cof-hero__video" id="heroVideo" autoplay loop muted playsinline>
      {% if theme.settings.hero_video_url %}
        <source src="{{ theme.settings.hero_video_url }}" type="video/mp4">
      {% else %}
        <source src="https://cdn.pixabay.com/video/2020/07/30/45349-445074842_large.mp4" type="video/mp4">
      {% endif %}
    </video>
    <div class="cof-hero__fallback"></div>
  </div>
  <div class="cof-hero__overlay"></div>
  <div class="cof-hero__vignette"></div>
  <div class="cof-hero__inner">
    <div class="cof-hero__content">
      <span class="cof-hero__label"><span class="cof-hero__label-line"></span>Specialty Roastery</span>
      <h1 class="cof-hero__title">
        {{ theme.settings.hero_title | default(trans('common.titles.hero_line1', 'Taste the Flavor of')) }}
        <strong>{{ theme.settings.hero_title_bold | default(trans('common.titles.hero_line2', 'Real Coffee')) }}</strong>
      </h1>
      <p class="cof-hero__sub">{{ theme.settings.hero_subtitle | default(trans('common.titles.hero_desc', 'Carefully selected beans from the finest farms, passionately roasted.')) }}</p>
      <div class="cof-hero__btns">
        <a href="{{ link('products') }}" class="cof-btn cof-btn--white">{{ trans('common.titles.shop_now', 'Shop Now') }}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><line x1="0" y1="8" x2="14" y2="8"/><polyline points="8,2 14,8 8,14"/></svg>
        </a>
        <a href="#subscription" class="cof-btn cof-btn--outline">{{ trans('common.titles.discover_subs', 'Discover Subscriptions') }}</a>
      </div>
      <div class="cof-hero__stats">
        <div><span class="cof-hero__stat-num">+{{ store.products_count | default('50') }}</span><span class="cof-hero__stat-lbl">{{ trans('common.titles.stat_products', 'Specialty varieties') }}</span></div>
        <div><span class="cof-hero__stat-num">{{ store.rating | default('4.9') }}</span><span class="cof-hero__stat-lbl">{{ trans('common.titles.stat_rating', 'Customer rating') }}</span></div>
        <div><span class="cof-hero__stat-num">+5K</span><span class="cof-hero__stat-lbl">{{ trans('common.titles.stat_customers', 'Happy customers') }}</span></div>
      </div>
    </div>
  </div>
  <div class="cof-hero__scroll"><div class="cof-hero__scroll-line"></div><span class="cof-hero__scroll-txt">Scroll</span></div>
  <button class="cof-hero__mute" id="muteBtn" aria-label="Toggle sound">
    <svg id="muteIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 5L6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
  </button>
</section>
