{# ── BREWING TOOLS ── #}
<section class="cof-sec" id="tools">
  <div class="cof-sec__head">
    <div><span class="cof-sec__tag">Brewing Tools</span><h2 class="cof-sec__title">{{ trans('common.titles.tools', 'Brewing') }} <strong>{{ trans('common.titles.brewing', 'Tools') }}</strong></h2></div>
    <a href="{{ link('products') }}" class="cof-sec__link">{{ trans('common.titles.view_all', 'View All') }}
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><line x1="0" y1="8" x2="14" y2="8"/><polyline points="8,2 14,8 8,14"/></svg>
    </a>
  </div>
  <div class="cof-tools">
    {% for product in products | slice(4, 3) %}
      <article class="cof-tool">
        <div class="cof-tool__ico">
          {% if product.image.url %}
            <img src="{{ product.image.url }}" alt="{{ product.name }}" width="38" height="38" style="object-fit:cover;border-radius:3px">
          {% else %}
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1"><path d="M3 10h14v7a4 4 0 01-4 4H7a4 4 0 01-4-4v-7z"/><path d="M17 12h1a3 3 0 010 6h-1"/><line x1="7" y1="2" x2="7" y2="5"/><line x1="10" y1="2" x2="10" y2="5"/><line x1="13" y1="2" x2="13" y2="5"/></svg>
          {% endif %}
        </div>
        <h3 class="cof-tool__name">{{ product.name }}</h3>
        <p class="cof-tool__desc">{{ product.description | striptags | truncate(60) }}</p>
        <div class="cof-tool__bot">
          <span class="cof-tool__price">{{ product.price }} <span class="cof-tool__cur">{{ product.currency }}</span></span>
          {% if product.rating and product.rating.count > 0 %}<div class="cof-prod__rate"><svg width="11" height="11" viewBox="0 0 12 12" fill="currentColor"><path d="M6 0l1.76 3.57 3.94.58-2.85 2.78.67 3.93L6 8.9l-3.52 1.96.67-3.93L.3 4.15l3.94-.58z"/></svg>{{ product.rating.stars }}</div>{% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>
