{# ── COFFEE HEADER — Replaces Raed's header ── #}
{# Transparent over hero, solid on scroll. Uses Salla's auth/cart web components. #}

<header id="mainnav" class="cof-header" style="position:fixed;top:0;left:0;right:0;z-index:100;background:transparent;transition:all .4s;border-bottom:1px solid transparent;">
  <div style="max-width:1320px;margin:0 auto;padding:0 2rem;height:60px;display:flex;align-items:center;justify-content:space-between;">

    {# ── Logo ── #}
    <a href="{{ link('/') }}" class="cof-header__logo" style="font-family:var(--cof-en,'DM Sans',sans-serif);font-size:1.1rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;text-decoration:none;display:flex;align-items:center;gap:.55rem;color:inherit;">
      <span style="width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1"><path d="M3 10h14v7a4 4 0 01-4 4H7a4 4 0 01-4-4v-7z"/><path d="M17 12h1a3 3 0 010 6h-1"/><line x1="7" y1="2" x2="7" y2="5"/><line x1="10" y1="2" x2="10" y2="5"/><line x1="13" y1="2" x2="13" y2="5"/></svg>
      </span>
      {{ store.name }}
    </a>

    {# ── Desktop Nav ── #}
    <nav class="cof-header__nav" style="display:flex;gap:2.2rem;">
      {% for item in store.menu %}
        <a href="{{ item.url }}" style="text-decoration:none;font-size:.8rem;font-weight:400;letter-spacing:.02em;transition:color .2s;">{{ item.title }}</a>
      {% endfor %}
    </nav>

    {# ── Actions ── #}
    <div style="display:flex;align-items:center;gap:1rem;">
      {# Search #}
      <salla-search-header></salla-search-header>

      {# Login/Profile #}
      <salla-user-menu></salla-user-menu>

      {# Cart #}
      <salla-cart-summary></salla-cart-summary>

      {# Mobile Menu Toggle #}
      <salla-main-menu id="mobile-menu"></salla-main-menu>
    </div>
  </div>
</header>
